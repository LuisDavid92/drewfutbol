              </div>
            ) : !leagueId ? (
              <div style={{
                textAlign: "center", padding: 50, color: "#556677",
                background: "#0d1526", borderRadius: 16, border: "1px solid #ffffff0d",
              }}>
                <div style={{ fontSize: 40, marginBottom: 12 }}>⚽</div>
                <div style={{ fontFamily: "'Oswald',sans-serif", fontSize: 18, color: "#8899bb", marginBottom: 8 }}>
                  {LEAGUE_INFO[activeLeague]?.name}
                </div>
                <div style={{ fontSize: 13, color: "#445566", marginBottom: 20 }}>
                  Esta liga no está disponible en el plan actual de la API.<br />
                  Consulta las noticias para datos actualizados.
                </div>
                <button onClick={() => setActiveTab("news")} style={{
                  padding: "10px 24px", borderRadius: 20, border: "none",
                  background: "linear-gradient(90deg,#00ff87,#00d4ff)",
                  color: "#000", fontWeight: 700, cursor: "pointer", fontSize: 13,
                }}>Ver Noticias de la Liga</button>
              </div>
            ) : filteredMatches.length === 0 ? (
              <div style={{ textAlign: "center", padding: 50, color: "#556677" }}>
                No hay partidos en este rango de fechas
              </div>
            ) : (
              filteredMatches.map(m => (
                <MatchCard key={m.id} match={m} channels={tvChannels} />
              ))
            )}
          </div>
        )}

        {/* STANDINGS TAB */}
        {activeTab === "standings" && (
          <div style={{ animation: "slideIn .3s ease" }}>
            {!leagueId ? (
              <div style={{ textAlign: "center", padding: 50, color: "#556677" }}>
                Liga no disponible en la API
              </div>
            ) : (
              <div style={{
                background: "#0d1526", border: "1px solid #ffffff0d",
                borderRadius: 16, padding: 16,
              }}>
                <div style={{ marginBottom: 12, display: "flex", gap: 16, fontSize: 11, color: "#556677" }}>
                  <span><span style={{ color: "#00ff87" }}>■</span> Champions</span>
                  <span><span style={{ color: "#4488ff" }}>■</span> Europa League</span>
                </div>
                <StandingsTable standings={standings} />
              </div>
            )}
          </div>
        )}

        {/* SCORERS TAB */}
        {activeTab === "scorers" && (
          <div style={{ animation: "slideIn .3s ease" }}>
            {!leagueId ? (
              <div style={{ textAlign: "center", padding: 50, color: "#556677" }}>Liga no disponible</div>
            ) : scorers.length === 0 ? (
              <div style={{ textAlign: "center", padding: 50, color: "#556677" }}>Cargando goleadores...</div>
            ) : (
              <div style={{ background: "#0d1526", border: "1px solid #ffffff0d", borderRadius: 16, overflow: "hidden" }}>
                {scorers.map((s, i) => (
                  <div key={s.player.id} style={{
                    display: "flex", alignItems: "center", gap: 14,
                    padding: "12px 18px",
                    borderBottom: i < scorers.length - 1 ? "1px solid #ffffff08" : "none",
                    background: i === 0 ? "#f0c04008" : "transparent",
                  }}>
                    <div style={{
                      width: 28, height: 28, borderRadius: "50%",
                      background: i === 0 ? "linear-gradient(135deg,#f0c040,#ff8800)" : i === 1 ? "linear-gradient(135deg,#aaaaaa,#666)" : i === 2 ? "linear-gradient(135deg,#cd7f32,#8b4513)" : "#1a2a3a",
                      display: "flex", alignItems: "center", justifyContent: "center",
                      fontSize: 12, fontWeight: 900, color: "#fff", flexShrink: 0,
                    }}>{i + 1}</div>
                    <TeamCrest url={s.team?.crest} name={s.team?.name} size={28} />
                    <div style={{ flex: 1 }}>
                      <div style={{ fontWeight: 700, fontSize: 14, color: "#e8eaf6" }}>{s.player.name}</div>
                      <div style={{ fontSize: 11, color: "#556677" }}>{s.team?.shortName || s.team?.name} · {s.player.nationality}</div>
                    </div>
                    <div style={{ textAlign: "right" }}>
                      <div style={{
                        fontFamily: "'Oswald',sans-serif", fontSize: 22, fontWeight: 900,
                        color: i === 0 ? "#f0c040" : "#00ff87",
                      }}>{s.goals}</div>
                      <div style={{ fontSize: 10, color: "#556677" }}>goles</div>
                    </div>
                    {s.assists != null && (
                      <div style={{ textAlign: "right", minWidth: 36 }}>
                        <div style={{ fontFamily: "'Oswald',sans-serif", fontSize: 16, fontWeight: 700, color: "#8899bb" }}>{s.assists}</div>
                        <div style={{ fontSize: 10, color: "#445566" }}>asist</div>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* NEWS TAB */}
        {activeTab === "news" && (
          <div style={{ animation: "slideIn .3s ease" }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
              <div style={{ fontSize: 13, color: "#556677" }}>Noticias recientes de {LEAGUE_INFO[activeLeague]?.name}</div>
              <button onClick={fetchNews} style={{
                padding: "6px 16px", borderRadius: 20, border: "1px solid #00ff8733",
                background: "#00ff8715", color: "#00ff87", fontSize: 12, fontWeight: 600,
                cursor: "pointer",
              }}>
                🔄 Actualizar
              </button>
            </div>
            {newsLoading ? (
              <div style={{ textAlign: "center", padding: 60 }}>
                <div style={{ fontSize: 32, marginBottom: 12, animation: "pulse 1s infinite" }}>📰</div>
                <div style={{ color: "#556677" }}>Buscando noticias en tiempo real...</div>
              </div>
            ) : news.length === 0 ? (
              <div style={{ textAlign: "center", padding: 50, color: "#556677" }}>
                <button onClick={fetchNews} style={{
                  padding: "12px 28px", borderRadius: 20, border: "none",
                  background: "linear-gradient(90deg,#00ff87,#00d4ff)",
                  color: "#000", fontWeight: 700, cursor: "pointer", fontSize: 14,
                }}>Cargar noticias</button>
              </div>
            ) : (
              news.map((n, i) => (
                <NewsCard key={i} title={n.title} summary={n.summary} source={n.source} date={n.date} url={n.url} />
              ))
            )}
          </div>
        )}
      </div>

      {/* FOOTER */}
      <div style={{
        textAlign: "center", padding: "20px 0 32px",
        color: "#334455", fontSize: 11, borderTop: "1px solid #ffffff05",
        marginTop: 20,
      }}>
        <span style={{ color: "#00ff8755", fontWeight: 700 }}>DREW FUTBOL</span>
        {" · "}Datos: football-data.org · Noticias: Claude AI
        <br />
        <span style={{ fontSize: 10 }}>Actualización en tiempo real · Todas las ligas del mundo</span>
      </div>
    </div>
  );
}
