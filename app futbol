      borderRadius: 16, padding: "16px 20px", marginBottom: 12,
      boxShadow: isLive ? "0 0 24px #00ff8722" : "0 4px 20px #00000055",
      transition: "all .3s",
      position: "relative", overflow: "hidden",
    }}>
      {isLive && (
        <div style={{
          position: "absolute", top: 0, left: 0, right: 0, height: 2,
          background: "linear-gradient(90deg,transparent,#00ff87,transparent)",
          animation: "pulse 2s infinite",
        }} />
      )}
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
        {/* Home */}
        <div style={{ flex: 1, textAlign: "right", display: "flex", alignItems: "center", justifyContent: "flex-end", gap: 10 }}>
          <span style={{ fontFamily: "'Oswald',sans-serif", fontSize: 14, fontWeight: 600, color: "#e8eaf6" }}>
            {match.homeTeam?.shortName || match.homeTeam?.name}
          </span>
          <TeamCrest url={match.homeTeam?.crest} name={match.homeTeam?.name} size={36} />
        </div>
        {/* Score / Time */}
        <div style={{ width: 90, textAlign: "center", padding: "0 8px" }}>
          {(isLive || isFinished) ? (
            <div style={{
              fontFamily: "'Oswald',sans-serif", fontSize: 22, fontWeight: 900,
              color: isLive ? "#00ff87" : "#fff",
              letterSpacing: 2,
            }}>
              {match.score?.fullTime?.home ?? 0} – {match.score?.fullTime?.away ?? 0}
            </div>
          ) : (
            <div style={{ color: "#f0c040", fontSize: 13, fontWeight: 700 }}>
              {formatTime(match.utcDate)}
            </div>
          )}
          <div style={{
            fontSize: 10, fontWeight: 700, marginTop: 4, padding: "2px 8px",
            borderRadius: 20, background: isLive ? "#00ff8722" : "#ffffff11",
            color: statusColor(match.status), letterSpacing: 1,
          }}>
            {isLive && <span style={{ marginRight: 4 }}>●</span>}
            {statusLabel(match.status)}
          </div>
        </div>
        {/* Away */}
        <div style={{ flex: 1, textAlign: "left", display: "flex", alignItems: "center", gap: 10 }}>
          <TeamCrest url={match.awayTeam?.crest} name={match.awayTeam?.name} size={36} />
          <span style={{ fontFamily: "'Oswald',sans-serif", fontSize: 14, fontWeight: 600, color: "#e8eaf6" }}>
            {match.awayTeam?.shortName || match.awayTeam?.name}
          </span>
        </div>
      </div>
      {/* TV Channels */}
      {channels && channels.length > 0 && (
        <div style={{ marginTop: 10, display: "flex", gap: 6, flexWrap: "wrap", justifyContent: "center" }}>
          <span style={{ fontSize: 11, color: "#8899bb", marginRight: 4 }}>📺</span>
